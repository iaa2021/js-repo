script-source,151,node:internal/crypto/kem,'use strict';\n\nconst {\n  FunctionPrototypeCall\x2C\n} = primordials;\n\nconst {\n  codes: {\n    ERR_CRYPTO_KEM_NOT_SUPPORTED\x2C\n  }\x2C\n} = require('internal/errors');\n\nconst {\n  validateFunction\x2C\n} = require('internal/validators');\n\nconst {\n  kCryptoJobAsync\x2C\n  kCryptoJobSync\x2C\n  KEMDecapsulateJob\x2C\n  KEMEncapsulateJob\x2C\n} = internalBinding('crypto');\n\nconst {\n  preparePrivateKey\x2C\n  preparePublicOrPrivateKey\x2C\n} = require('internal/crypto/keys');\n\nconst {\n  getArrayBufferOrView\x2C\n} = require('internal/crypto/util');\n\nfunction encapsulate(key\x2C callback) {\n  if (!KEMEncapsulateJob)\n    throw new ERR_CRYPTO_KEM_NOT_SUPPORTED();\n\n  if (callback !== undefined)\n    validateFunction(callback\x2C 'callback');\n\n  const {\n    data: keyData\x2C\n    format: keyFormat\x2C\n    type: keyType\x2C\n    passphrase: keyPassphrase\x2C\n  } = preparePublicOrPrivateKey(key);\n\n  const job = new KEMEncapsulateJob(\n    callback ? kCryptoJobAsync : kCryptoJobSync\x2C\n    keyData\x2C\n    keyFormat\x2C\n    keyType\x2C\n    keyPassphrase);\n\n  if (!callback) {\n    const { 0: err\x2C 1: result } = job.run();\n    if (err !== undefined)\n      throw err;\n    const { 0: sharedKey\x2C 1: ciphertext } = result;\n    return { sharedKey\x2C ciphertext };\n  }\n\n  job.ondone = (error\x2C result) => {\n    if (error) return FunctionPrototypeCall(callback\x2C job\x2C error);\n    const { 0: sharedKey\x2C 1: ciphertext } = result;\n    FunctionPrototypeCall(callback\x2C job\x2C null\x2C { sharedKey\x2C ciphertext });\n  };\n  job.run();\n}\n\nfunction decapsulate(key\x2C ciphertext\x2C callback) {\n  if (!KEMDecapsulateJob)\n    throw new ERR_CRYPTO_KEM_NOT_SUPPORTED();\n\n  if (callback !== undefined)\n    validateFunction(callback\x2C 'callback');\n\n  const {\n    data: keyData\x2C\n    format: keyFormat\x2C\n    type: keyType\x2C\n    passphrase: keyPassphrase\x2C\n  } = preparePrivateKey(key);\n\n  ciphertext = getArrayBufferOrView(ciphertext\x2C 'ciphertext');\n\n  const job = new KEMDecapsulateJob(\n    callback ? kCryptoJobAsync : kCryptoJobSync\x2C\n    keyData\x2C\n    keyFormat\x2C\n    keyType\x2C\n    keyPassphrase\x2C\n    ciphertext);\n\n  if (!callback) {\n    const { 0: err\x2C 1: result } = job.run();\n    if (err !== undefined)\n      throw err;\n\n    return result;\n  }\n\n  job.ondone = (error\x2C result) => {\n    if (error) return FunctionPrototypeCall(callback\x2C job\x2C error);\n    FunctionPrototypeCall(callback\x2C job\x2C null\x2C result);\n  };\n  job.run();\n}\n\nmodule.exports = {\n  encapsulate\x2C\n  decapsulate\x2C\n};\n

script-source,138,node:internal/crypto/argon2,'use strict';\n\nconst {\n  FunctionPrototypeCall\x2C\n  MathPow\x2C\n  StringPrototypeToLowerCase\x2C\n  TypedArrayPrototypeGetBuffer\x2C\n  Uint8Array\x2C\n} = primordials;\n\nconst { Buffer } = require('buffer');\n\nconst {\n  Argon2Job\x2C\n  kCryptoJobAsync\x2C\n  kCryptoJobSync\x2C\n  kTypeArgon2d\x2C\n  kTypeArgon2i\x2C\n  kTypeArgon2id\x2C\n} = internalBinding('crypto');\n\nconst {\n  lazyDOMException\x2C\n  promisify\x2C\n} = require('internal/util');\n\nconst {\n  getArrayBufferOrView\x2C\n  kKeyObject\x2C\n} = require('internal/crypto/util');\n\nconst {\n  validateString\x2C\n  validateFunction\x2C\n  validateInteger\x2C\n  validateObject\x2C\n  validateOneOf\x2C\n  validateUint32\x2C\n} = require('internal/validators');\n\nconst {\n  codes: {\n    ERR_CRYPTO_ARGON2_NOT_SUPPORTED\x2C\n  }\x2C\n} = require('internal/errors');\n\n/**\n * @param {'argon2d' | 'argon2i' | 'argon2id'} algorithm\n * @param {object} parameters\n * @param {ArrayBufferLike} parameters.message\n * @param {ArrayBufferLike} parameters.nonce\n * @param {number} parameters.parallelism\n * @param {number} parameters.tagLength\n * @param {number} parameters.memory\n * @param {number} parameters.passes\n * @param {ArrayBufferLike} [parameters.secret]\n * @param {ArrayBufferLike} [parameters.associatedData]\n * @param {Function} callback\n */\nfunction argon2(algorithm\x2C parameters\x2C callback) {\n  parameters = check(algorithm\x2C parameters);\n\n  validateFunction(callback\x2C 'callback');\n\n  const job = new Argon2Job(\n    kCryptoJobAsync\x2C\n    parameters.message\x2C\n    parameters.nonce\x2C\n    parameters.parallelism\x2C\n    parameters.tagLength\x2C\n    parameters.memory\x2C\n    parameters.passes\x2C\n    parameters.secret\x2C\n    parameters.associatedData\x2C\n    parameters.type);\n\n  job.ondone = (error\x2C result) => {\n    if (error !== undefined)\n      return FunctionPrototypeCall(callback\x2C job\x2C error);\n    const
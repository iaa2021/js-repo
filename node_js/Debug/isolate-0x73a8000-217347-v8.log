script-source,126,node:internal/errors/error_source,'use strict';\n\nconst {\n  FunctionPrototypeBind\x2C\n  StringPrototypeSlice\x2C\n} = primordials;\n\nconst {\n  getErrorSourcePositions\x2C\n} = internalBinding('errors');\nconst {\n  getSourceMapsSupport\x2C\n  findSourceMap\x2C\n  getSourceLine\x2C\n} = require('internal/source_map/source_map_cache');\n\n/**\n * Get the source location of an error. If source map is enabled\x2C resolve the source location\n * based on the source map.\n *\n * The `error.stack` must not have been accessed. The resolution is based on the structured\n * error stack data.\n * @param {Error|object} error An error object\x2C or an object being invoked with ErrorCaptureStackTrace\n * @returns {{sourceLine: string\x2C startColumn: number}|undefined}\n */\nfunction getErrorSourceLocation(error) {\n  const pos = getErrorSourcePositions(error);\n  const {\n    sourceLine\x2C\n    scriptResourceName\x2C\n    lineNumber\x2C\n    startColumn\x2C\n  } = pos;\n\n  // Source map is not enabled. Return the source line directly.\n  if (!getSourceMapsSupport().enabled) {\n    return { sourceLine\x2C startColumn };\n  }\n\n  const sm = findSourceMap(scriptResourceName);\n  if (sm === undefined) {\n    return;\n  }\n  const {\n    originalLine\x2C\n    originalColumn\x2C\n    originalSource\x2C\n  } = sm.findEntry(lineNumber - 1\x2C startColumn);\n  const originalSourceLine = getSourceLine(sm\x2C originalSource\x2C originalLine\x2C originalColumn);\n\n  if (!originalSourceLine) {\n    return;\n  }\n\n  return {\n    sourceLine: originalSourceLine\x2C\n    startColumn: originalColumn\x2C\n  };\n}\n\nconst memberAccessTokens = [ '.'\x2C '?.'\x2C '['\x2C ']' ];\nconst memberNameTokens = [ 'name'\x2C 'string'\x2C 'num' ];\nlet tokenizer;\n/**\n * Get the first expression in a code string at the startColumn.\n * @param {string} code source code line\n * @param {number} startColumn which column the error is constructed\n * @returns {string}\n */\nfunction getFirstExpression(code\x2C startColumn) {\n  // Lazy load acorn.\n  if (tokenizer === undefined) {\n    const Parser = require('internal/deps/acorn/acorn/dist/acorn').Parser;\n    tokenizer = FunctionPrototypeBind(Parser.tokenizer\x2C Parser);\n  }\n\n  let lastToken;\n  let firstMemberAccessNameToken;\n  let terminatingCol;\n  let parenLvl = 0;\n  // Tokenize the line to locate the expression at the startColumn.\n  // The source line may be an incomplete JavaScript source\x2C so do not parse the source line.\n  for (const token of tokenizer(code\x2C { ecmaVersion: 'latest' })) {\n    // Peek before the startColumn.\n    if (token.start < startColumn) {\n      // There is a semicolon. This is a statement before the startColumn\x2C so reset the memo.\n      if (token.type.label === ';') {\n        firstMemberAccessNameToken = null;\n        continue;\n      }\n      // Try to memo the member access expressions before the startColumn\x2C so that the\n      // returned source code contains more info:\n      //   assert.ok(value)\n      //          ^ startColumn\n      // The member expression can also be like\n      //   assert['ok'](value) or assert?.ok(value)\n      //               ^ startColumn      ^ startColumn\n      if (memberAccessTokens.includes(token.type.label) && lastToken?.type.label === 'name') {\n        // First member access name token must be a 'name'.\n        firstMemberAccessNameToken ??= lastToken;\n      } else if (!memberAccessTokens.includes(token.type.label) &&\n        !memberNameTokens.includes(token.type.label)) {\n        // Reset the memo if it is not a simple member access.\n        // For example: assert[(() => 'ok')()](value)\n        //                                    ^ startColumn\n        firstMemberAccessNameToken = null;\n      }\n      lastToken = token;\n      continue;\n    }\n    // Now after the startColumn\x2C this must be an expression.\n    if (token.type.label === '(') {\n      parenLvl++;\n      continue;\n    }\n    if (token.type.label === ')') {\n      parenLvl--;\n      if (parenLvl === 0) {\n        // A matched closing parenthesis found after the startColumn\x2C\n        // terminate here. Include the token.\n        //   (assert.ok(false)\x2C assert.ok(true))\n        //           ^ startColumn\n        terminatingCol = token.start + 1;\n        break;\n      }\n      continue;\n    }\n    if (token.type.label === ';') {\n      // A semicolon found after the startColumn\x2C terminate here.\n      //   assert.ok(false); assert.ok(true));\n      //          ^ startColumn\n      terminatingCol = token;\n      break;\n    }\n    // If no semicolon found after the startColumn. The string after the\n    // startColumn must be the expression.\n    //   assert.ok(false)\n    //          ^ startColumn\n  }\n  const start = firstMemberAccessNameToken?.start ?? startColumn;\n  return StringPrototypeSlice(code\x2C start\x2C terminatingCol);\n}\n\n/**\n * Get the source expression of an error. If source map is enabled\x2C resolve the source location\n * based on the source map.\n *\n * The `error.stack` must not have been accessed\x2C or the source location may be incorrect. The\n * resolution is based on the structured error stack data.\n * @param {Error|object} error An error object\x2C or an object being invoked with ErrorCaptureStackTrace\n * @returns {string|undefined}\n */\nfunction getErrorSourceExpression(error) {\n  const loc = getErrorSourceLocation(error);\n  if (loc === undefined) {\n    return;\n  }\n  const { sourceLine\x2C startColumn } = loc;\n  return getFirstExpression(sourceLine\x2C startColumn);\n}\n\nmodule.exports = {\n  getErrorSourceLocation\x2C\n  getErrorSourceExpression\x2C\n};\n
